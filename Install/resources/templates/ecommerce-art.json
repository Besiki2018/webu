{
  "name": "Art & Prints Store",
  "theme_preset": "creative_portfolio",
  "default_pages": [
    {
      "slug": "home",
      "title": "Home",
      "sections": [
        { "key": "webu_general_heading_01", "props": { "headline": "Art for Your Space", "subtitle": "Prints, originals, and limited editions. Curated for collectors.", "layout_variant": "centered", "style_variant": "minimal" } },
        { "key": "webu_ecom_product_grid_01", "props": { "title": "Featured Works", "products_per_page": 8, "show_filters": false, "show_sort": false, "layout_variant": "standard", "style_variant": "softshadow" } },
        { "key": "webu_general_heading_01", "props": { "headline": "Browse by Style", "subtitle": "Abstract, landscape, portrait, modern.", "layout_variant": "centered", "style_variant": "minimal" } },
        { "key": "webu_ecom_product_grid_01", "props": { "title": "Popular This Month", "products_per_page": 6, "show_filters": false, "show_sort": false, "layout_variant": "standard", "style_variant": "softshadow" } },
        { "key": "webu_general_testimonials_01", "props": { "title": "Collector Stories", "layout_variant": "carousel", "style_variant": "card" } },
        { "key": "webu_general_newsletter_01", "props": { "title": "New drops and artist news" } }
      ]
    },
    { "slug": "shop", "title": "Shop", "sections": [
        { "key": "webu_ecom_product_search_01", "props": { "title": "Search", "variant": "inline" } },
        { "key": "webu_ecom_product_grid_01", "props": { "title": "All Artworks", "show_filters": true, "show_sort": true, "pagination_mode": "pagination" } }
    ]},
    { "slug": "product", "title": "Product", "sections": [
        { "key": "webu_ecom_product_gallery_01", "props": { "product_slug": "{{route.params.slug}}" } },
        { "key": "webu_ecom_product_detail_01", "props": { "product_slug": "{{route.params.slug}}" } },
        { "key": "webu_ecom_product_tabs_01", "props": { "product_slug": "{{route.params.slug}}" } }
    ]},
    { "slug": "cart", "title": "Cart", "sections": [
        { "key": "webu_ecom_cart_page_01", "props": { "title": "Your Cart", "show_coupon_slot": true, "show_order_summary": true } }
    ]},
    { "slug": "checkout", "title": "Checkout", "sections": [
        { "key": "webu_ecom_checkout_form_01", "props": { "title": "Checkout", "variant": "combined" } }
    ]},
    { "slug": "contact", "title": "Contact", "sections": [
        { "key": "webu_general_heading_01", "props": { "headline": "Get in Touch", "subtitle": "Commissions, framing, or questions.", "layout_variant": "centered", "style_variant": "minimal" } },
        { "key": "webu_general_text_01", "props": { "title": "Contact", "body": "Email or call. We respond within 24 hours." } }
    ]}
  ]
}
