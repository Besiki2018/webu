{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "barryvdh/laravel-dompdf": "^3.1",
        "claude-php/claude-php-sdk": "^0.5.3",
        "google/recaptcha": "^1.3",
        "inertiajs/inertia-laravel": "^2.0",
        "khaled.alshamaa/ar-php": "^7.0",
        "kreait/firebase-php": "^8.1",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.7",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^2.10.1",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.3",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "App\\Plugins\\PaymentGateways\\": [
                "app/Plugins/PaymentGateways/PayPal/src/",
                "app/Plugins/PaymentGateways/BankTransfer/src/",
                "app/Plugins/PaymentGateways/Stripe/src/",
                "app/Plugins/PaymentGateways/Paystack/src/",
                "app/Plugins/PaymentGateways/Razorpay/src/",
                "app/Plugins/PaymentGateways/CryptoCom/src/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check-php-version": [
            "@php -r \"if (version_compare(PHP_VERSION, '8.4.0', '<')) { fwrite(STDERR, 'PHP 8.4+ is required. Current: '.PHP_VERSION.PHP_EOL); exit(1); }\""
        ],
        "setup": [
            "@check-php-version",
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "@check-php-version",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#86efac,#f9a8d4\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan reverb:start --host=0.0.0.0 --port=8002\" \"bash scripts/start-local-builder.sh\" --names=server,queue,logs,vite,reverb,builder --kill-others"
        ],
        "test": [
            "@check-php-version",
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
