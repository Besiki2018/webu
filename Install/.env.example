APP_NAME=Webby
APP_ENV=production
APP_KEY=base64:cGxhY2Vob2xkZXJrZXlmb3J3ZWJieWluc3RhbGxlcjE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=ka
APP_FALLBACK_LOCALE=en

# Demo Mode Configuration (only used when APP_DEMO=true AND APP_ENV=local)
APP_DEMO=
APP_DEMO_AI_KEY=
APP_DEMO_PUSHER_APPID=
APP_DEMO_PUSHER_KEY=
APP_DEMO_PUSHER_SECRET=
APP_DEMO_PUSHER_CLUSTER=

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=30
LOG_LEVEL=error

# Ops alerts & structured logs
OPS_STRUCTURED_LOG_CHANNEL=ops_structured
OPS_STRUCTURED_INCLUDE_STACKTRACES=false
OPS_STRUCTURED_FORMATTER_MAX_DEPTH=6
OPS_STRUCTURED_FORMATTER_MAX_ITEMS=250
OPS_STRUCTURED_CONTEXT_MAX_DEPTH=5
OPS_STRUCTURED_CONTEXT_MAX_ITEMS=200
OPS_STRUCTURED_CONTEXT_MAX_STRING=2000
OPS_ALERT_LOG_CHANNEL=ops_alerts
OPS_ALERTS_ENABLED=true
OPS_ALERT_DEDUPE_SECONDS=300
OPS_ALERT_STACK=ops_structured
OPS_ALERT_EMAIL_ENABLED=false
OPS_ALERT_EMAIL_OVERRIDE=
OPS_ALERT_CRITICAL_CHANNELS=build,publish,payment,subscription,system
OPS_ALERT_CRITICAL_EVENTS=preview_build_failed,publish_unexpected_exception,webhook_exception,payment_initiation_failed,webhook_gateway_not_found,subscription_expire_failed,subscription_renewal_reminder_failed,subscriptions_manage_failed,stale_build_checker_failed,stale_build_hard_timeout,stale_build_session_missing
OPS_LOG_LEVEL=info
OPS_LOG_DAYS=30
OPS_ALERT_SLACK_WEBHOOK_URL=
OPS_ALERT_SLACK_LEVEL=critical
OPS_ALERT_SLACK_USERNAME="Webby Ops"
OPS_ALERT_SLACK_EMOJI=:rotating_light:

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync
CACHE_STORE=file
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"

# NOTE: App configurations (Pusher/Reverb, Firebase, social login, email, builders, etc.)
# are managed via Admin Panel (/admin/*), not .env

# Admin Bugfixer "Run auto fix": path to npm binary or its directory (if npm not in server PATH)
# BUGFIXER_NPM_PATH=/usr/local/bin/npm

# Local prebuilt builder runtime (used by `composer dev`)
BUILDER_PORT=8846
BUILDER_SERVER_KEY=123456

# CMS demo content seeding for newly provisioned sites
CMS_DEMO_CONTENT_ENABLED=true
CMS_DEMO_CONTENT_SEED_IN_TESTING=false

# Ecommerce RS sync (F21 skeleton)
ECOMMERCE_RS_SYNC_CONNECTOR=rs-v2-skeleton
ECOMMERCE_RS_SYNC_QUEUE=default
ECOMMERCE_RS_SYNC_MAX_ATTEMPTS=5

# Booking notifications/reminders (G5)
BOOKING_NOTIFICATIONS_QUEUE=default
SUBSCRIPTION_MAX_RETRIES=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24
SUBSCRIPTION_GRACE_DAYS=5
SUBSCRIPTION_FALLBACK_TO_DEFAULT_PLAN_ON_SUSPEND=true
BOOKING_REMINDER_MINUTES_BEFORE_START=120
BOOKING_REMINDER_DISPATCH_WINDOW_MINUTES=10
BOOKING_REMINDER_BATCH_LIMIT=500

# Domain SSL provisioning (I2)
DOMAIN_SSL_MAX_ATTEMPTS=5
DOMAIN_SSL_RETRY_BACKOFF_MINUTES=15

# Enterprise dedicated DB mode (L7 skeleton)
TENANCY_DEDICATED_DB_ENABLED=false
